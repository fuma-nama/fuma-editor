// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}


enum CmsRole {
  admin
  editor
  viewer
}

enum CmsPostStatus {
  draft
  published
  archived
}

enum CmsPublishTargetProvider {
  github
  local_fs @map("local-fs")
}

enum CmsPublishJobStatus {
  pending
  running
  succeeded
  failed
}

enum CmsSnapshotScope {
  central
  target
}

enum CmsRealtimeDocKind {
  body
  meta
}

enum CmsPublishEventLevel {
  info
  warn
  error
}

model CmsWorkspace {
  id String @id
  slug String
  name String
  createdAt DateTime
  updatedAt DateTime
  @@map("cms_workspace")
}

model CmsWorkspaceMember {
  workspaceId String
  userId String
  role CmsRole
  createdAt DateTime
  updatedAt DateTime

  @@id([workspaceId, userId])
  @@map("cms_workspace_member")
}

model CmsPost {
  id String @id
  workspaceId String
  slug String
  title String
  description String
  body String
  status CmsPostStatus
  version Int
  publishedAt DateTime?
  deletedAt DateTime?
  deletedBy String?
  createdBy String
  updatedBy String
  createdAt DateTime
  updatedAt DateTime
  @@map("cms_post")
}

model CmsPostSnapshot {
  id String @id
  postId String
  workspaceId String
  scope CmsSnapshotScope
  targetId String?
  data Json
  ownedPaths String[]
  contentHash String
  createdBy String?
  createdAt DateTime
  @@map("cms_post_snapshot")
}

model CmsPublishTarget {
  id String @id
  workspaceId String
  provider CmsPublishTargetProvider
  name String
  config Json
  active Boolean
  createdAt DateTime
  updatedAt DateTime
  @@map("cms_publish_target")
}

model CmsPublishJob {
  id String @id
  workspaceId String
  postId String
  targetId String
  status CmsPublishJobStatus
  delta Json
  outputRef String?
  errorMessage String?
  startedAt DateTime?
  finishedAt DateTime?
  createdBy String?
  createdAt DateTime
  @@map("cms_publish_job")
}

model CmsPublishEvent {
  id String @id
  jobId String
  level CmsPublishEventLevel
  message String
  payload Json
  createdAt DateTime
  @@map("cms_publish_event")
}

model CmsRealtimeDoc {
  id String @id
  postId String
  workspaceId String
  docName String
  kind CmsRealtimeDocKind
  state Bytes
  updatedAt DateTime
  createdAt DateTime
  @@map("cms_realtime_doc")
}
